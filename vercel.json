{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/js/:path*", "destination": "/js/:path*" },
    { "source": "/html/:path*", "destination": "/html/:path*" },
    { "source": "/styles/:path*", "destination": "/styles/:path*" },
    { "source": "/data/:path*", "destination": "/data/:path*" },
    { "source": "/:path*", "destination": "/:path*" }
  ]
}
